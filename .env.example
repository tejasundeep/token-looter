# ─────────────────────────────────────────────────────────────────────────────
# TokenLooter — Environment Configuration Template
# ─────────────────────────────────────────────────────────────────────────────
# Rename this file to `.env` and configure your environment.

# ── Server ────────────────────────────────────────────────────────────────────
# Port the local server listens on (default: 8000)
PORT=8000
HOST=127.0.0.1

# ── Analytics Retention ───────────────────────────────────────────────────────
# Keep database history clean by pruning older logs.
REQUEST_ANALYTICS_RETENTION_DAYS=90
REQUEST_ANALYTICS_MAX_ROWS=100000

# ── Context Handoff ───────────────────────────────────────────────────────────
# Inject context summary when the routed model changes mid-session.
# Options: off (default) | on_model_switch
TOKENLOOTER_CONTEXT_HANDOFF=on_model_switch

# ── Database ──────────────────────────────────────────────────────────────────
# Path to the SQLite analytics database. Defaults to data/freeapi.db
# DATABASE_PATH=data/freeapi.db

# ── Proxy ─────────────────────────────────────────────────────────────────────
# Route outbound provider requests through an HTTP/HTTPS proxy.
# PROXY_URL=http://user:pass@proxy.example.com:8080
